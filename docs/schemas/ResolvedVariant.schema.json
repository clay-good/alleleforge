{
  "$defs": {
    "AmbiguousRegion": {
      "description": "A reference region known to be unreliable on hg38.",
      "properties": {
        "interval": {
          "$ref": "#/$defs/GenomicInterval"
        },
        "kind": {
          "$ref": "#/$defs/RegionFlagKind"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "required": [
        "interval",
        "kind"
      ],
      "title": "AmbiguousRegion",
      "type": "object"
    },
    "ClinVarAccession": {
      "description": "A validated ClinVar accession (``VCV``/``RCV``/``SCV`` form).",
      "properties": {
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "ClinVarAccession",
      "type": "object"
    },
    "Consequence": {
      "description": "A Sequence-Ontology-style molecular consequence term.",
      "enum": [
        "transcript_ablation",
        "splice_acceptor_variant",
        "splice_donor_variant",
        "stop_gained",
        "frameshift_variant",
        "stop_lost",
        "start_lost",
        "inframe_insertion",
        "inframe_deletion",
        "missense_variant",
        "splice_region_variant",
        "synonymous_variant",
        "5_prime_UTR_variant",
        "3_prime_UTR_variant",
        "intron_variant",
        "upstream_gene_variant",
        "downstream_gene_variant",
        "intergenic_variant",
        "other"
      ],
      "title": "Consequence",
      "type": "string"
    },
    "CoordinateSystem": {
      "description": "Coordinate convention. Internal everything is 0-based half-open.",
      "enum": [
        "0-based-half-open",
        "1-based-inclusive"
      ],
      "title": "CoordinateSystem",
      "type": "string"
    },
    "DbSnpId": {
      "description": "A validated dbSNP rsID (``rs`` followed by digits).",
      "properties": {
        "value": {
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "DbSnpId",
      "type": "object"
    },
    "GenomicInterval": {
      "description": "A strand-aware genomic interval, 0-based half-open by default.\n\nAttributes:\n    chrom: Contig / chromosome name (e.g. ``\"chr2\"``).\n    start: Inclusive start coordinate.\n    end: Exclusive end coordinate (``start <= end``).\n    strand: The strand the interval is reported on.\n    coordinate_system: The coordinate convention of ``start``/``end``.",
      "properties": {
        "chrom": {
          "title": "Chrom",
          "type": "string"
        },
        "coordinate_system": {
          "$ref": "#/$defs/CoordinateSystem",
          "default": "0-based-half-open"
        },
        "end": {
          "title": "End",
          "type": "integer"
        },
        "start": {
          "title": "Start",
          "type": "integer"
        },
        "strand": {
          "$ref": "#/$defs/Strand"
        }
      },
      "required": [
        "chrom",
        "start",
        "end",
        "strand"
      ],
      "title": "GenomicInterval",
      "type": "object"
    },
    "Impact": {
      "description": "VEP impact tier (ordered so the most severe compares greatest).",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "title": "Impact",
      "type": "integer"
    },
    "ReferenceRecommendation": {
      "description": "The outcome of flagging an interval against ambiguous-region tables.\n\nAttributes:\n    query: The interval that was checked.\n    source_build: The build the query is expressed in.\n    recommended_build: The build to switch to, or ``None`` if no flag fired.\n    regions: The ambiguous regions the query overlaps.",
      "properties": {
        "query": {
          "$ref": "#/$defs/GenomicInterval"
        },
        "recommended_build": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Recommended Build"
        },
        "regions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/AmbiguousRegion"
          },
          "title": "Regions",
          "type": "array"
        },
        "source_build": {
          "title": "Source Build",
          "type": "string"
        }
      },
      "required": [
        "query",
        "source_build",
        "recommended_build"
      ],
      "title": "ReferenceRecommendation",
      "type": "object"
    },
    "RegionFlagKind": {
      "description": "Why a locus is flagged as hg38-ambiguous.",
      "enum": [
        "segdup",
        "centromeric",
        "hg38-difficult"
      ],
      "title": "RegionFlagKind",
      "type": "string"
    },
    "Strand": {
      "description": "Genomic strand. Always explicit; AlleleForge has no \"default strand\".",
      "enum": [
        "+",
        "-"
      ],
      "title": "Strand",
      "type": "string"
    },
    "Variant": {
      "description": "A normalized sequence variant in 0-based coordinates.\n\nAttributes:\n    chrom: Contig / chromosome name.\n    pos: 0-based start coordinate of the ``ref`` allele.\n    ref: Reference allele (may be empty for a pure insertion after trimming).\n    alt: Alternate allele (may be empty for a pure deletion after trimming).\n    build: Reference genome build (e.g. ``\"hg38\"``).\n    hgvs_g: Optional genomic HGVS string.\n    hgvs_c: Optional coding HGVS string.\n    hgvs_p: Optional protein HGVS string.\n    clinvar: Optional source ClinVar accession.\n    rsid: Optional source dbSNP rsID.",
      "properties": {
        "alt": {
          "title": "Alt",
          "type": "string"
        },
        "build": {
          "default": "hg38",
          "title": "Build",
          "type": "string"
        },
        "chrom": {
          "title": "Chrom",
          "type": "string"
        },
        "clinvar": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClinVarAccession"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "hgvs_c": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hgvs C"
        },
        "hgvs_g": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hgvs G"
        },
        "hgvs_p": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hgvs P"
        },
        "pos": {
          "title": "Pos",
          "type": "integer"
        },
        "ref": {
          "title": "Ref",
          "type": "string"
        },
        "rsid": {
          "anyOf": [
            {
              "$ref": "#/$defs/DbSnpId"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "chrom",
        "pos",
        "ref",
        "alt"
      ],
      "title": "Variant",
      "type": "object"
    },
    "VariantEffect": {
      "description": "A variant's structured molecular consequence on one transcript.\n\nAttributes:\n    consequence: The most severe Sequence-Ontology consequence term.\n    impact: The VEP impact tier of ``consequence``.\n    gene: The affected gene symbol, if any.\n    transcript: The transcript the consequence is reported against.\n    hgvs_c: Coding HGVS string, if the variant is transcribed.\n    hgvs_p: Protein HGVS string, if the variant is translated.\n    is_canonical: Whether ``transcript`` is the MANE Select / canonical one.",
      "properties": {
        "consequence": {
          "$ref": "#/$defs/Consequence"
        },
        "gene": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gene"
        },
        "hgvs_c": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hgvs C"
        },
        "hgvs_p": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hgvs P"
        },
        "impact": {
          "$ref": "#/$defs/Impact"
        },
        "is_canonical": {
          "default": true,
          "title": "Is Canonical",
          "type": "boolean"
        },
        "transcript": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transcript"
        }
      },
      "required": [
        "consequence",
        "impact"
      ],
      "title": "VariantEffect",
      "type": "object"
    }
  },
  "description": "The canonical result of resolving any input form.\n\nAttributes:\n    variant: The normalized, left-aligned, reference-validated variant.\n    working_interval: The +/- ``window`` analysis interval around it.\n    source: The input form it was resolved from (audit aid).\n    transcript: The transcript consequence is reported against.\n    effect: The molecular consequence, if an effect predictor was supplied.\n    reference_recommendation: A T2T recommendation when the locus is\n        hg38-ambiguous, else ``None``.",
  "properties": {
    "effect": {
      "anyOf": [
        {
          "$ref": "#/$defs/VariantEffect"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "reference_recommendation": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReferenceRecommendation"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "source": {
      "title": "Source",
      "type": "string"
    },
    "transcript": {
      "default": "MANE_SELECT",
      "title": "Transcript",
      "type": "string"
    },
    "variant": {
      "$ref": "#/$defs/Variant"
    },
    "working_interval": {
      "$ref": "#/$defs/GenomicInterval"
    }
  },
  "required": [
    "variant",
    "working_interval",
    "source"
  ],
  "title": "ResolvedVariant",
  "type": "object"
}
